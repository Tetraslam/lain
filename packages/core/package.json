{
  "name": "@lain/core",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --external bun:sqlite --external chokidar --external gray-matter --external unpdf",
    "dev": "tsup src/index.ts --format esm --dts --watch",
    "test": "bun test",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@lain/agents": "workspace:*",
    "@lain/shared": "workspace:*",
    "chokidar": "^5.0.0",
    "gray-matter": "^4.0.3",
    "unpdf": "^1.6.2"
  },
  "devDependencies": {
    "bun-types": "^1.3.12"
  }
}
