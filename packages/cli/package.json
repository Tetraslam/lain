    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@clack/prompts": "^1.2.0",
    "@lain/agents": "workspace:*",
    "@lain/core": "workspace:*",
    "@lain/shared": "workspace:*",
    "gray-matter": "^4.0.3"
  }
}
