{
  "name": "@lain/cli",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "lain": "./dist/index.js"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts",
    "dev": "tsup src/index.ts --format esm --watch --onSuccess 'echo build done'",
